{
  "expo": {
    "name": "FocusKit",
    "slug": "focuskit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1226"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.nyx.focuskit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f1226"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nyx.focuskit"
    },
    "description": "A calm, private, ADHD-friendly focus and planner app. Local-first, no account, no ads."
  }
}
