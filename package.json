{
  "name": "focuskit",
  "version": "0.1.0",
  "description": "FocusKit by Nyx — a calm, private, ADHD-friendly focus & planner app. Local-first. No account. No ads.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
